#!/usr/bin/env sh
# prepare-commit-msg runs AFTER the commit message is prepared (from -m, -F,
# template, etc.) but BEFORE the commit is created. That gives us access to
# the message in $1 and lets us add files to the index that will be part of
# the commit.
#
# We use it to:
#   1. Detect the bump level from the conventional-commit prefix
#   2. Update version files via scripts/increment-version.mjs
#   3. Build production assets (which embed the new version)
#   4. git add all the version-bearing files so they ship with this commit

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="$2"   # "message" (-m), "template", "merge", "squash", "commit" (-c/--amend)

# Skip on merge / squash / amend so we don't accidentally double-bump.
case "$COMMIT_SOURCE" in
  merge|squash|commit)
    exit 0
    ;;
esac

# Skip when ONLY version-bearing files are staged (manual / explicit version
# commits). This avoids double-bumping when someone is fixing a version typo.
HAS_NON_VERSION_CHANGES=""
for FILE in $(git diff --cached --name-only); do
  case "$FILE" in
    package.json|CHANGELOG.json|client/public/CHANGELOG.json|client/public/version.json|client/src/hooks/useUpdateCheck.ts|client/src/components/VersionFooter.tsx|client/index.html)
      ;;
    *)
      HAS_NON_VERSION_CHANGES="yes"
      break
      ;;
  esac
done

if [ -z "$HAS_NON_VERSION_CHANGES" ]; then
  exit 0
fi

# Determine bump level from the message.
COMMIT_MSG=""
if [ -n "$BUMP_LEVEL" ]; then
  LEVEL="$BUMP_LEVEL"
elif [ -f "$COMMIT_MSG_FILE" ]; then
  COMMIT_MSG=$(grep -v '^#' "$COMMIT_MSG_FILE" | sed -n '/[^[:space:]]/p' | head -n 1)
fi

if [ -z "$LEVEL" ]; then
  case "$COMMIT_MSG" in
    *"BREAKING CHANGE"*|*"BREAKING-CHANGE"*)
      LEVEL="major"
      ;;
    feat\!:*|fix\!:*|refactor\!:*|perf\!:*|build\!:*|chore\!:*|feat\(*\)\!:*|fix\(*\)\!:*|refactor\(*\)\!:*|perf\(*\)\!:*|build\(*\)\!:*|chore\(*\)\!:*)
      LEVEL="major"
      ;;
    feat:*|feat\(*\):*)
      LEVEL="minor"
      ;;
    *)
      LEVEL="patch"
      ;;
  esac
fi

echo "[prepare-commit-msg] Auto-Version-Bump (${LEVEL}) — message head: ${COMMIT_MSG%%$'\n'*}"
node scripts/increment-version.mjs "$LEVEL" || exit 1
node scripts/generate-version.js || exit 1

echo "[prepare-commit-msg] Production-Build wird erstellt..."
npx vite build && npx esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist || exit 1

git add \
  package.json \
  CHANGELOG.json \
  client/public/CHANGELOG.json \
  client/src/hooks/useUpdateCheck.ts \
  client/src/components/VersionFooter.tsx \
  client/index.html \
  client/public/version.json
