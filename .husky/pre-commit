#!/usr/bin/env sh
# Tests run early so a broken codebase fails before the user finishes the
# commit. Version bump + build are deferred to post-commit because git's index
# is locked between pre-commit and the actual commit creation, so any
# version-bump hook that runs earlier cannot include its own changes in the
# resulting commit.
echo "[pre-commit] Unit-Tests werden ausgeführt..."
npx vitest run server/taxEnginePl.test.ts server/uiValidationReportsDashboard.test.ts
