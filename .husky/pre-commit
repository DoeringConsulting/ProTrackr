#!/usr/bin/env sh

HAS_NON_VERSION_CHANGES=""
for FILE in $(git diff --cached --name-only); do
  case "$FILE" in
    package.json|CHANGELOG.json|client/public/CHANGELOG.json|client/public/version.json|client/src/hooks/useUpdateCheck.ts|client/src/components/VersionFooter.tsx|client/index.html)
      ;;
    *)
      HAS_NON_VERSION_CHANGES="yes"
      break
      ;;
  esac
done

if [ -n "$HAS_NON_VERSION_CHANGES" ]; then
  echo "[pre-commit] Sync version across all files"
  node scripts/sync-version.mjs
  node scripts/generate-version.js
  git add package.json CHANGELOG.json client/public/CHANGELOG.json client/src/hooks/useUpdateCheck.ts client/src/components/VersionFooter.tsx client/index.html client/public/version.json
fi

echo "[pre-commit] Unit-Tests werden ausgeführt..."
npx vitest run server/taxEnginePl.test.ts server/uiValidationReportsDashboard.test.ts

echo "[pre-commit] Production-Build wird erstellt..."
node scripts/generate-version.js
npx vite build && npx esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist
