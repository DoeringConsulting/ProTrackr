# =============================================================================
# ProTrackr — Production Environment Template
# =============================================================================
# THIS FILE IS A TEMPLATE. Never put real secrets here.
#
# Usage:
#   1. Copy to .env (same directory as docker-compose.yml)
#   2. Replace every CHANGE_ME_* placeholder with a real value
#   3. .env is in .gitignore — never commit real credentials
#
# On Unraid: prefer Container Variables (masked) in the Unraid UI over an
# on-disk .env. Either approach works with docker-compose.yml.
#
# Secret generation tips:
#   openssl rand -hex 32       (for SESSION_SECRET, JWT_SECRET, etc. — 64 chars)
#   openssl rand -base64 24    (for DB passwords — URL-safe-ish, ~32 chars)
# =============================================================================


# --- Application -------------------------------------------------------------
NODE_ENV=production
PORT=3000
# PORT is the container-internal port. Tailscale Serve on the NAS maps this to
# the external https://dcs01.taile370c2.ts.net:9443 .


# --- Session & Auth Secrets --------------------------------------------------
# MUST be 32+ chars. Use openssl rand -hex 32 to generate each one separately.
SESSION_SECRET=CHANGE_ME_32_CHARS_MIN
JWT_SECRET=CHANGE_ME_32_CHARS_MIN
SCHEDULER_API_KEY=CHANGE_ME_32_CHARS_MIN
CRON_SECRET=CHANGE_ME_32_CHARS_MIN


# --- Session Cookies ---------------------------------------------------------
# In production behind Tailscale (HTTPS), set SECURE=true so cookies are only
# sent over TLS. SAMESITE=lax is the default safe choice for same-site auth.
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax


# --- Database (MySQL container, internal docker network) ---------------------
# Hostname "mysql" matches the service name in docker-compose.yml.
# IMPORTANT: the password in DATABASE_URL must EXACTLY equal MYSQL_PASSWORD below.
DATABASE_URL=mysql://protrackr_user:CHANGE_ME_DB_PASSWORD@mysql:3306/protrackr

# MySQL container init variables (only used on first container start)
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_DATABASE=protrackr
MYSQL_USER=protrackr_user
MYSQL_PASSWORD=CHANGE_ME_DB_PASSWORD


# --- SMTP (hoste.pl mail server, for password-reset emails) ------------------
SMTP_HOST=doeringconsulting.hoste.pl
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=office@doering-consulting.eu
SMTP_PASS=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=office@doering-consulting.eu
#
# Auth-Method Note:
# hoste.pl was configured by the user with "MD5 Challenge-Response" auth
# (CRAM-MD5). Nodemailer normally picks the auth method automatically from
# the EHLO server response. If first send fails with EAUTH after the NAS
# is up, edit server/email.ts and add:
#     auth: { user, pass }, authMethod: 'CRAM-MD5'
# in the createTransport() call (around line 42). Then rebuild the container.


# --- Vite Frontend Build Variables (cosmetic) --------------------------------
# Der App-Titel kommt seit §6.4 (2026-07-06) zur LAUFZEIT über APP_ENV_LABEL (Server-
# injiziert). Prod setzt APP_ENV_LABEL NICHT (siehe docker-compose.yml) → der Client
# zeigt den Prod-Titel. VITE_APP_TITLE wird nicht mehr genutzt.
VITE_APP_LOGO=


# --- Unused in self-hosted deployment (leave empty) --------------------------
# These were used by the previous Manus-hosted deployment. Keep keys present
# so the app's env-parser doesn't warn about missing variables.
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=
OWNER_OPEN_ID=
OWNER_NAME=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
