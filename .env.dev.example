# =============================================================================
# ProTrackr — DEV / Staging Environment Template
# =============================================================================
# Vorlage für die Dev-Umgebung (compose.dev.yml). TEMPLATE — keine echten
# Secrets hier. Kopieren nach .env.dev und CHANGE_ME_* ersetzen.
#
#   cp .env.dev.example .env.dev  &&  chmod 600 .env.dev   (auf dem NAS)
#
# ISOLATION: Die Dev-Secrets MÜSSEN andere sein als Prod (.env). Nie dieselbe
# DB, nie dasselbe Passwort. Frisch generieren:
#   openssl rand -hex 32     (SESSION/JWT/SCHEDULER/CRON)
#   openssl rand -hex 24     (DB-Passwörter)
# =============================================================================


# --- Application -------------------------------------------------------------
NODE_ENV=production
PORT=3000
# PORT ist container-intern (3000). Host-Port ist 3011 (in compose.dev.yml).
# Tailscale Serve mappt später https://dcs01.taile370c2.ts.net:9444 → :3011.

TZ=Europe/Warsaw


# --- Session & Auth Secrets (EIGENE, NICHT die Prod-Werte!) ------------------
SESSION_SECRET=CHANGE_ME_DEV_32_CHARS_MIN
JWT_SECRET=CHANGE_ME_DEV_32_CHARS_MIN
SCHEDULER_API_KEY=CHANGE_ME_DEV_32_CHARS_MIN
CRON_SECRET=CHANGE_ME_DEV_32_CHARS_MIN


# --- Session Cookies ---------------------------------------------------------
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax


# --- Database (dev-mysql-Container, isoliertes dev-Netzwerk) ------------------
# Host "mysql" = Service-Name in compose.dev.yml → im dev-Netzwerk auf
# protrackr-mysql-dev aufgelöst. KEIN Weg zur Prod-DB.
# WICHTIG: Passwort in DATABASE_URL == MYSQL_PASSWORD unten.
DATABASE_URL=mysql://protrackr_user:CHANGE_ME_DEV_DB_PASSWORD@mysql:3306/protrackr

MYSQL_ROOT_PASSWORD=CHANGE_ME_DEV_ROOT_PASSWORD
MYSQL_DATABASE=protrackr
MYSQL_USER=protrackr_user
MYSQL_PASSWORD=CHANGE_ME_DEV_DB_PASSWORD


# --- SMTP (in Dev standardmäßig LEER — keine echten Mails aus Test-Umgebung) --
# Leer lassen = Passwort-Reset-Mails werden nicht versendet (App läuft normal).
# Nur füllen, wenn du den Mailversand in Dev testen willst (dann Test-Postfach,
# NICHT das produktive office@… mit echten Empfängern).
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=


# --- Vite Frontend Build Variables (cosmetic) --------------------------------
# Optional: Dev optisch kennzeichnen, damit man Dev nicht mit Prod verwechselt.
VITE_APP_TITLE="ProTrackr (DEV)"
VITE_APP_LOGO=


# --- Unused in self-hosted deployment (leer lassen) --------------------------
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=
OWNER_OPEN_ID=
OWNER_NAME=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
